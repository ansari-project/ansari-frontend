            {
              "name": "server",
              "value": "railway-edge"
            },
            {
              "name": "vary",
              "value": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch"
            },
            {
              "name": "x-railway-edge",
              "value": "railway/asia-southeast1-eqsg3a"
