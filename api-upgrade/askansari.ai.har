            "mimeType": "application/json",
            "text": "{\"content\":\"Can you suggest some duas for making charitable acts during Ramadan more meaningful?\",\"role\":\"user\"}"
          }
        },
        "response": {
          "status": 200,
          "statusText": "",
          "httpVersion": "http/2.0",
          "headers": [
            {
              "name": "access-control-allow-credentials",
